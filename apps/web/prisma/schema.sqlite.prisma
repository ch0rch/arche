generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-desktop"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  slug         String   @unique
  role         String   @default("USER")
  kind         String   @default("HUMAN")
  passwordHash String   @map("password_hash")
  totpEnabled    Boolean  @default(false) @map("totp_enabled")
  totpSecret     String?  @map("totp_secret")
  totpVerifiedAt DateTime? @map("totp_verified_at")
  totpLastUsedAt DateTime? @map("totp_last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sessions           Session[]
  auditEvents        AuditEvent[] @relation("AuditActor")
  instance           Instance?
  twoFactorRecovery  TwoFactorRecovery[]
  connectors         Connector[]
  providerCredentials ProviderCredential[]
  autopilotTasks      AutopilotTask[]
  slackThreadBindings SlackThreadBinding[]
  slackUserLinks      SlackUserLink[]
  slackDmSessionBindings SlackDmSessionBinding[]

  @@map("users")
}

model ExternalIntegration {
  key       String   @id @map("key")
  config    String   // AES-256-GCM encrypted JSON
  state     String?  @default("{}")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("external_integrations")
}

model SlackThreadBinding {
  id               String   @id @default(cuid())
  channelId        String   @map("channel_id")
  threadTs         String   @map("thread_ts")
  openCodeSessionId String  @map("opencode_session_id")
  executionUserId  String   @map("execution_user_id")
  executionUser    User     @relation(fields: [executionUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([channelId, threadTs])
  @@index([executionUserId])
  @@map("slack_thread_bindings")
}

model SlackEventReceipt {
  id         String   @id @default(cuid())
  eventId    String   @unique @map("event_id")
  type       String
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([receivedAt])
  @@map("slack_event_receipts")
}

model SlackUserLink {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  slackTeamId String   @map("slack_team_id")
  slackUserId String   @map("slack_user_id")
  slackEmail  String?  @map("slack_email")
  displayName String?  @map("display_name")
  lastSeenAt  DateTime @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slackTeamId, slackUserId])
  @@index([userId])
  @@map("slack_user_links")
}

model SlackDmSessionBinding {
  id                String   @id @default(cuid())
  slackTeamId       String   @map("slack_team_id")
  slackUserId       String   @map("slack_user_id")
  channelId         String   @map("channel_id")
  executionUserId   String   @map("execution_user_id")
  openCodeSessionId String   @unique @map("opencode_session_id")
  startedAt         DateTime @default(now()) @map("started_at")
  lastMessageAt     DateTime @default(now()) @map("last_message_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  executionUser     User     @relation(fields: [executionUserId], references: [id], onDelete: Cascade)

  @@index([slackTeamId, slackUserId, lastMessageAt])
  @@index([executionUserId])
  @@map("slack_dm_session_bindings")
}

model SlackPendingDmDecision {
  id                         String   @id @default(cuid())
  sourceEventId              String   @unique @map("source_event_id")
  slackTeamId                String   @map("slack_team_id")
  slackUserId                String   @map("slack_user_id")
  channelId                  String   @map("channel_id")
  sourceTs                   String   @map("source_ts")
  messageText                String   @map("message_text")
  previousDmSessionBindingId String?  @map("previous_dm_session_binding_id")
  expiresAt                  DateTime @map("expires_at")
  status                     String   @default("pending")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("slack_pending_dm_decisions")
}

model SlackNotificationChannel {
  id          String   @id @default(cuid())
  slackTeamId String   @map("slack_team_id")
  channelId   String   @map("channel_id")
  name        String
  isPrivate   Boolean  @default(false) @map("is_private")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([slackTeamId, channelId])
  @@map("slack_notification_channels")
}

model Instance {
  id              String   @id @default(cuid())
  slug            String   @unique

  status          String   @default("stopped")

  createdAt       DateTime @default(now()) @map("created_at")
  startedAt       DateTime? @map("started_at")
  stoppedAt       DateTime? @map("stopped_at")
  lastActivityAt  DateTime? @map("last_activity_at")

  containerId     String?  @map("container_id")
  serverPassword  String   @map("server_password")
  appliedConfigSha String? @map("applied_config_sha")
  providerSyncHash String? @map("provider_sync_hash")
  providerSyncedAt DateTime? @map("provider_synced_at")

  user            User     @relation(fields: [slug], references: [slug])

  @@index([status])
  @@map("instances")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique @map("token_hash")

  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastSeenAt DateTime? @map("last_seen_at")

  ip        String? @map("ip")
  userAgent String? @map("user_agent")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  action    String
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_events")
}

model MessageRun {
  id         String   @id
  slug       String
  sessionId  String   @map("opencode_session_id")
  source     String
  status     String   @default("running")
  error      String?
  startedAt  DateTime @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lock       MessageRunLock?

  @@index([slug, sessionId, status])
  @@index([startedAt])
  @@map("message_runs")
}

model MessageRunLock {
  slug      String
  sessionId String   @map("opencode_session_id")
  runId     String   @unique @map("run_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  run       MessageRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@id([slug, sessionId])
  @@index([runId])
  @@map("message_run_locks")
}

model AutopilotTask {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  cronExpression String   @map("cron_expression")
  timezone       String
  prompt         String
  targetAgentId  String?  @map("target_agent_id")
  enabled        Boolean  @default(true)
  slackNotificationConfig String? @map("slack_notification_config")

  nextRunAt      DateTime @map("next_run_at")
  lastRunAt      DateTime? @map("last_run_at")
  leaseOwner     String?  @map("lease_owner")
  leaseExpiresAt DateTime? @map("lease_expires_at")
  retryAttempt   Int      @default(0) @map("retry_attempt")
  retryScheduledFor DateTime? @map("retry_scheduled_for")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  runs           AutopilotRun[]

  @@index([userId])
  @@index([enabled, nextRunAt])
  @@index([leaseExpiresAt])
  @@index([userId, leaseExpiresAt])
  @@index([retryScheduledFor])
  @@map("autopilot_tasks")
}

model AutopilotRun {
  id              String   @id @default(cuid())
  taskId          String   @map("task_id")
  task            AutopilotTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  status          String
  trigger         String
  scheduledFor    DateTime @map("scheduled_for")
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  error           String?
  openCodeSessionId String? @unique @map("opencode_session_id")
  sessionTitle    String?  @map("session_title")
  resultSeenAt    DateTime? @map("result_seen_at")
  attempt          Int      @default(1)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([taskId, startedAt])
  @@index([status])
  @@index([scheduledFor])
  @@map("autopilot_runs")
}

model Connector {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String
  name      String
  config    String
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("connectors")
}

model ProviderCredential {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String    @map("provider_id")
  type       String
  status     String    @default("enabled")
  version    Int
  secret     String
  lastError  String?   @map("last_error")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([providerId])
  @@map("provider_credentials")
}

model TwoFactorRecovery {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("two_factor_recovery")
}
