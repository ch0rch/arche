DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arche?schema=public"

# Dominio base (cuando integres Traefik/subdominios). En local puedes usar `arche.lvh.me`.
ARCHE_DOMAIN="arche.lvh.me"

# Opcional. Si se define, se usa tal cual (ej: .arche.example.com). Si no, se deriva de ARCHE_DOMAIN.
ARCHE_COOKIE_DOMAIN=""

# Requerido en produccion. En desarrollo, si no se define se usa un valor inseguro.
ARCHE_SESSION_PEPPER=""

# TTL de sesion (dias)
ARCHE_SESSION_TTL_DAYS="7"

# Seed primer admin (idempotente)
ARCHE_SEED_ADMIN_EMAIL="admin@example.com"
ARCHE_SEED_ADMIN_PASSWORD="change-me"
ARCHE_SEED_ADMIN_SLUG="admin"
