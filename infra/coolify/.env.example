# Arche — Coolify Environment Variables
# Configure these in Coolify's UI or copy to .env

# =============================================================================
# REQUIRED — Domain
# =============================================================================
ARCHE_DOMAIN=arche.example.com

# =============================================================================
# REQUIRED — Secrets (generate each with: openssl rand -base64 32)
# =============================================================================
ARCHE_SESSION_PEPPER=
ARCHE_ENCRYPTION_KEY=
ARCHE_INTERNAL_TOKEN=

# =============================================================================
# REQUIRED — Initial Admin Account
# =============================================================================
ARCHE_SEED_ADMIN_EMAIL=admin@example.com
ARCHE_SEED_ADMIN_PASSWORD=
ARCHE_SEED_ADMIN_SLUG=admin

# =============================================================================
# OPTIONAL — Container Configuration
# =============================================================================
# OpenCode workspace image (default: ghcr.io/anomalyco/opencode:1.1.45)
# OPENCODE_IMAGE=ghcr.io/anomalyco/opencode:1.1.45

# =============================================================================
# OPTIONAL — Knowledge Base
# =============================================================================
# Host paths to bare repos used by kickstart/runtime (must exist on the VPS)
# KB_CONTENT_HOST_PATH=/opt/arche/kb-content
# KB_CONFIG_HOST_PATH=/opt/arche/kb-config

# =============================================================================
# OPTIONAL — Cookie Settings
# =============================================================================
# Set to false only for local development without HTTPS
# ARCHE_COOKIE_SECURE=true
